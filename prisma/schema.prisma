generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id              String      @id @default(cuid())
  slug            String      @unique
  name            String
  description     String
  longDescription String?
  hookTitle       String
  features        String
  price           Float
  oldPrice        Float?
  images          String
  ageGroup        String
  type            String
  stock           Int         @default(0)
  showStock       Boolean     @default(true)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  orderItems      OrderItem[]
}

model Order {
  id           String      @id @default(cuid())
  orderNumber  String      @unique
  firstName    String
  lastName     String
  phone        String
  wilayaCode   String
  wilayaName   String
  commune      String
  deliveryType String
  address      String
  notes        String?
  subtotal     Float
  discount     Float       @default(0)
  deliveryFee  Float
  total        Float
  promoCode    String?
  status       String      @default("NEW")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  items        OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model PromoCode {
  id        String    @id @default(cuid())
  code      String    @unique
  type      String    // "PERCENT" | "FIXED"
  value     Float
  minOrder  Float     @default(0)
  maxUses   Int?
  usedCount Int       @default(0)
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

model Setting {
  key   String @id
  value String
}
